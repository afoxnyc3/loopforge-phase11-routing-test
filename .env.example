# Supabase project URL — found in your Supabase project settings under API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — found in your Supabase project settings under API
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# NOTE: These are public-facing keys safe for client-side use.
# Never commit your service_role key to version control.
